*
/*/

# Root level whitelists
!.gitignore
!README.md
!README_DEV.md
!SETUP.md
!GITIGNORE_CHECKLIST.md
!PROJECT_CONTEXT.md
!Procfile
!railway.toml
!server.py
!run_app.py
!seed_data.py
!requirements.txt
!requirements-server.txt
!config.json
!note.txt

# Backend folder and files
!backend/
!backend/*.py
!backend/*.txt
!backend/*.toml
!backend/Procfile

# Frontend (Python legacy)
!frontend/
!frontend/*.py

# Flutter frontend - ALL files and folders
!flutter_frontend/
!flutter_frontend/**


# Python cache & venv
**/__pycache__/
**/*.pyc
*.egg-info/
.Python
build/
dist/
*.egg
venv/
env/
ENV/
.venv

# Environment
.env
.env.local
.env.*.local

# Flutter & Dart - BUILD OUTPUTS ONLY
flutter_frontend/build/
flutter_frontend/.dart_tool/
flutter_frontend/.flutter-plugins
flutter_frontend/.flutter-plugins-dependencies
flutter_frontend/.packages
flutter_frontend/pubspec.lock
flutter_frontend/**/.g.dart
flutter_frontend/**/*.g.dart
flutter_frontend/**/doc/api/
flutter_frontend/**/.dart_tool/
flutter_frontend/**/build/
flutter_frontend/android/.gradle/
flutter_frontend/android/local.properties
flutter_frontend/ios/Pods/
flutter_frontend/macos/Pods/
flutter_frontend/windows/flutter/ephemeral/
flutter_frontend/linux/flutter/ephemeral/

