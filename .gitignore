!PROJECT_CONTEXT.md
!Procfile
!railway.toml
!server.py
!run_app.py
!seed_data.py
!requirements.txt
!requirements-server.txt
!crash_log.txt
!shop.db
!config.json
!note.txt

# Backend folder and files
!backend/
!backend/*.py
!backend/*.txt
!backend/*.toml
!backend/Procfile

# Frontend (Python legacy)
!frontend/
!frontend/*.py


# Python cache & venv
**/__pycache__/
**/*.pyc
*.egg-info/
.Python
build/
dist/
*.egg
venv/
env/
ENV/
.venv

# Environment
.env
.env.local
.env.*.local

